# MIPI-DSI Configuration for ESP32-P4
CONFIG_MIPI_DSI_ENABLED=y
CONFIG_MIPI_DSI_BUS_COUNT=1
CONFIG_MIPI_DSI_SUPPORT=y

# LCD Panel Support
CONFIG_ESP_LCD_MIPI_DSI_SUPPORTED=y
CONFIG_ESP_LCD_EK79007_SUPPORTED=y

# PSRAM
CONFIG_ESP_PSRAM=y
CONFIG_SPIRAM=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_FETCH_INSTRUCTIONS=y
CONFIG_SPIRAM_RODATA=y

# LDO for MIPI DSI PHY
CONFIG_PM_SUPPORT=y
CONFIG_PM_POWER_DOWN_PERIPHERAL_IN_LIGHT_SLEEP=y

# USB
CONFIG_USB_OTG_SUPPORTED=y

# Arduino main task stack size - increased for MIPI-DSI init
CONFIG_ARDUINO_LOOP_STACK_SIZE=32768

# ISR IRAM-safe flags for PSRAM cache coherency
CONFIG_RMT_ISR_IRAM_SAFE=y
CONFIG_GPTIMER_ISR_IRAM_SAFE=y

# ─── ESP-Hosted: C6 co-processor for BLE ───
CONFIG_ESP_HOSTED_ENABLED=y
CONFIG_ESP_HOSTED_ENABLE_BT_NIMBLE=y
CONFIG_ESP_HOSTED_SDIO_HOST_INTERFACE=y
CONFIG_SLAVE_IDF_TARGET_ESP32C6=y

# SDIO pin configuration (P4 -> C6 co-processor)
CONFIG_ESP_HOSTED_SDIO_PIN_CLK=18
CONFIG_ESP_HOSTED_SDIO_PIN_CMD=19
CONFIG_ESP_HOSTED_SDIO_PIN_D0=14
CONFIG_ESP_HOSTED_SDIO_PIN_D1=15
CONFIG_ESP_HOSTED_SDIO_PIN_D2=16
CONFIG_ESP_HOSTED_SDIO_PIN_D3=17
CONFIG_ESP_HOSTED_GPIO_SLAVE_RESET_SLAVE=54
CONFIG_ESP_HOSTED_SDIO_BUS_WIDTH=4
CONFIG_ESP_HOSTED_SDIO_SLOT=1
CONFIG_ESP_HOSTED_SDIO_CLOCK_FREQ_KHZ=20000
CONFIG_ESP_HOSTED_SDIO_CHECKSUM=y
CONFIG_ESP_HOSTED_SDIO_TX_Q_SIZE=40
CONFIG_ESP_HOSTED_SDIO_RX_Q_SIZE=40

# Reset strategy
CONFIG_ESP_HOSTED_SLAVE_RESET_ON_EVERY_HOST_BOOTUP=y

# ─── Bluetooth (NimBLE Host via ESP-Hosted) ───
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_NIMBLE_ENABLED=y
CONFIG_BT_CONTROLLER_DISABLED=y
CONFIG_BT_NIMBLE_HOST_ONLY=y
CONFIG_BT_NIMBLE_50_FEATURE_SUPPORT=y
CONFIG_BT_BLE_42_FEATURES_SUPPORTED=y
CONFIG_BT_GATTC_MAX_SR_PROFILES=1
CONFIG_BT_GATTS_MAX_SR_PROFILES=1
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=1

# ─── Wi-Fi Remote (C6 slave target) ───
CONFIG_WIFI_REMOTE=y
